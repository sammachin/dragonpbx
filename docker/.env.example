# DragonPBX Docker Configuration

# Drachtio shared secret
DRACHTIO_SECRET=cymru

# Configuration API endpoint and auth token
CONFIG_URL=http://your-config-api:1337/api/v1/domains
CONFIG_TOKEN=your-api-token

# Config source: api, json, or pg
DATA_SOURCE=api

# Config cache TTL in seconds
CONFIG_TTL=60

# Log level: fatal, error, warn, info, debug, trace
LOGLEVEL=info
